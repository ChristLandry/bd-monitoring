# Chiffrement credentials (32 octets hex = AES-256)
ENCRYPTION_KEY=a3f8c2e91b4d7f0e6a2c8e4f1b9d3a7c5e8f2a1b6d4c9e0f3a7b2d8e1c6f4a9

